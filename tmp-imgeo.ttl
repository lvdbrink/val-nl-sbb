        rdfs:label             "bestaand"@nl;
        skos:definition        "Situatie waarin het object wordt / kan worden gebruikt voor het doel waarvoor het is gebouwd / aangelegd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bestaand"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bestaand> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Historie>
