        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "coupure"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Coupure> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Duiker>
        a                      skos:Concept;
        rdfs:label             "duiker"@nl;
        skos:definition        "Kunstwerk voor de waterhuishouding, bestaande uit een kokervormige constructie aangebracht onder een weg of spoorweg of in een dam."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "duiker"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Duiker> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Faunavoorziening>
        a                      skos:Concept;
        rdfs:label             "faunavoorziening"@nl;
        skos:definition        "Voorziening bij een weg of spoorweg, niet zijnde een ecoduct, om de uit dat werk voortvloeiende negatieve gevolgen voor de fauna zoveel mogelijk te voorkomen of te beperken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "faunavoorziening"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Faunavoorziening> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Keermuur>
        a                      skos:Concept;
        rdfs:label             "keermuur"@nl;
        skos:definition        "Een keermuur of keerwand is een stijf, grond- of waterkerend kunstwerk dat door een groot gewicht en een brede voet een grote standzekerheid kan bereiken. Een keermuur is meestal van gewapend beton, maar er kan ook ander materiaal gebruikt worden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "keermuur"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Keermuur> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Overkluizing>
        a                      skos:Concept;
        rdfs:label             "overkluizing"@nl;
        skos:definition        "Een overkluizing is een civieltechnisch kunstwerk waarmee een weg een andere weg, een plein of een waterloop (kruiselings) overwelft. In het geval van een waterweg is er onder het bouwwerk (vaak) geen scheepvaart mogelijk, maar ligt het wateroppervlak nog wel vrij. Een overkluizing is te vergelijken met een brug, alleen bestaat de brug in dit geval vaak niet uit een wegdek maar uit een opstal. Anders gesteld: het maakt meestal geen deel uit van een weg."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "overkluizing"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Overkluizing> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Ponton>
        a                      skos:Concept;
        rdfs:label             "ponton"@nl;
        skos:definition        "Drijvende, dichte bak, waarover soms een dek is gelegd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "ponton"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Ponton> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Vispassage>
        a                      skos:Concept;
        rdfs:label             "vispassage"@nl;
        skos:definition        "Een kunstmatige passage ten behoeve van de vistrek bij kunstwerken in wateren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "vispassage"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Vispassage> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeMast>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeMast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bovenleidingmast>
        a                      skos:Concept;
        rdfs:label             "bovenleidingmast"@nl;
        skos:definition        "Mast die een onderdeel vormt van de bovenleidingdraagconstructie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bovenleidingmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bovenleidingmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Laagspanningsmast>
        a                      skos:Concept;
        rdfs:label             "laagspanningsmast"@nl;
        skos:definition        "Houten of metalen mast waaraan kabels voor het transport van elektrische energie met een spannning lager dan 500 V zijn bevestigd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "laagspanningsmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Laagspanningsmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Radarmast>
        a                      skos:Concept;
        rdfs:label             "radarmast"@nl;
        skos:definition        "Vaste of neerklapbare constructie waarop de radarantenne bevestigd is."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "radarmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Radarmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Straalzender>
        a                      skos:Concept;
        rdfs:label             "straalzender"@nl;
        skos:definition        "Zender voor radio, televisie en telecommunicatie signalen die in smalle stralenbundels uitzendt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "straalzender"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Straalzender> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zendmast>
        a                      skos:Concept;
        rdfs:label             "zendmast"@nl;
        skos:definition        "Mast bestemd voor het uitzenden van radio, televisie of telecommunicatie signalen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "zendmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Zendmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/OeverSlootkant>
        a                      skos:Concept;
        rdfs:label             "oever, slootkant"@nl;
        skos:definition        "De strook land die in direct contact staat met water, inclusief het gebied tussen de hoogwaterlijn en laagwaterlijn."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "oever, slootkant"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/OeverSlootkant> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Slik>
        a                      skos:Concept;
        rdfs:label             "slik"@nl;
        skos:definition        "Buitendijks aangeslibde, onbegroeide grond die bij vrijwel elk hoogwater onderloopt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "slik"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Slik> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_typeOndersteunendWaterdeel>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_typeOndersteunendWaterdeel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/AdministratiefGebied>
        a                      skos:Concept;
        rdfs:label             "Administratief gebied"@nl;
        skos:definition        "Een niet tastbaar begrensd grondoppervlak dat als eenheid geldt voor bestuurlijke verantwoordelijkheid, voor bedrijfsvoering, waarbinnen een specifieke rechtsverhouding te onderscheiden is of waarvoor een specifieke functie of bestemming geldt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Administratief gebied"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/AdministratiefGebied> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kunstwerk>
        a                      skos:Concept;
        rdfs:label             "Kunstwerk"@nl;
        skos:definition        "Civiel-technisch werk voor de infrastructuur van wegen, water, spoorbanen, waterkeringen en/of leidingen en niet bedoeld voor permanent menselijk verblijf."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Kunstwerk"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kunstwerk> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/LandschappelijkGebied>
        a                      skos:Concept;
        rdfs:label             "Landschappelijk gebied"@nl;
        skos:definition        "Definitie ontbreekt in de BAG."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Landschappelijk gebied"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/LandschappelijkGebied> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Spoorbaan_typeOpenbareRuimte>
        a                      skos:Concept;
        rdfs:label             "Spoorbaan"@nl;
        skos:definition        "Gebaand gedeelte voor het verkeer over rails."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Spoorbaan"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Spoorbaan_typeOpenbareRuimte> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Terrein>
        a                      skos:Concept;
        rdfs:label             "Terrein"@nl;
        skos:definition        "Door een fysiek voorkomen gekarakteriseerd zichtbaar begrensd stuk grond."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Terrein"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Terrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Water>
        a                      skos:Concept;
        rdfs:label             "Water"@nl;
        skos:definition        "Grondoppervlak in principe bedekt met water."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Water"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Water> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Aquaduct>
        a                      skos:Concept;
        rdfs:label             "aquaduct"@nl;
        skos:definition        "Kunstwerk waarmee een watergang door een bakvormige constructie over een weg, een spoorweg, een andere watergang, een leiding of een terrein wordt geleid."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "aquaduct"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Aquaduct> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Brug>
        a                      skos:Concept;
        rdfs:label             "brug"@nl;
        skos:definition        "Kunstwerk over een watervlakte of waterloop, bestaande uit een brugdek gesteund door pijlers en/of landhoofden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "brug"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Brug> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Ecoduct>
        a                      skos:Concept;
        rdfs:label             "ecoduct"@nl;
        skos:definition        "Wildwissel in de vorm van een viaduct voor passages van dieren over een weg of spoorweg."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "ecoduct"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Ecoduct> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Fly-over>
        a                      skos:Concept;
        rdfs:label             "fly-over"@nl;
        skos:definition        "Kunstwerk in de vorm van een viaduct dat deel uitmaakt van een verkeersbaan en waarmee een verkeersstroom over twee of meer ongelijkvloerse verkeersstromen wordt geleid."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "fly-over"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Fly-over> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Viaduct>
        a                      skos:Concept;
        rdfs:label             "viaduct"@nl;
        skos:definition        "Kunstwerk over een weg, spoorweg of terreinverdieping, bestaande uit een dek gesteund door pijlers en/of landhoofden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "viaduct"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Viaduct> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Dek>
        a                      skos:Concept;
        rdfs:label             "dek"@nl;
        skos:definition        "Direct door het verkeer belaste deel van de bovenbouw van de brug."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "dek"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Dek> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Landhoofd>
        a                      skos:Concept;
        rdfs:label             "landhoofd"@nl;
        skos:definition        "Ondersteuningsconstructie ter plaatse van een overgang van de aardebaan naar een kunstwerk."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "landhoofd"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Landhoofd> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Pijler>
        a                      skos:Concept;
        rdfs:label             "pijler"@nl;
        skos:definition        "Ondersteuningsconstructie van bruggen en soortgelijke kunstwerken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "pijler"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Pijler> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Pyloon>
        a                      skos:Concept;
        rdfs:label             "pyloon"@nl;
        skos:definition        "Boven de bovenbouw uitstekende draagconstructie voor tuien (kabels)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "pyloon"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Pyloon> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Sloof>
        a                      skos:Concept;
        rdfs:label             "sloof"@nl;
        skos:definition        "Deel van de pijler voor de overdracht van krachten naar de ondergrond of de fundering."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "sloof"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Sloof> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/LageTrafo>
        a                      skos:Concept;
        rdfs:label             "lage trafo"@nl;
        skos:definition        "Bouwwerk waarin transformator(en) zijn geplaatst voor elektriciteitsvoorziening."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "lage trafo"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/LageTrafo> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeOverigBouwwerk>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeOverigBouwwerk> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_typeOverigBouwwerk>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_typeOverigBouwwerk> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Schuur>
        a                      skos:Concept;
        rdfs:label             "schuur"@nl;
        skos:definition        "Een vrijstaand, al of niet prefab, niet-vergunningsplichtig bouwwerk dat gebruikt wordt om goederen in op te slaan en ook als werkruimte kan dienen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "schuur"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Schuur> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Voedersilo>
        a                      skos:Concept;
        rdfs:label             "voedersilo"@nl;
        skos:definition        "Opslagfaciliteit voor veevoer, bestaande uit een verticale container met een opening aan de onderkant."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "voedersilo"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Voedersilo> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typePaal>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typePaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Afsluitpaal>
        a                      skos:Concept;
        rdfs:label             "afsluitpaal"@nl;
        skos:definition        "Al dan niet verwijderbare paal in de grond om de weg of een gedeelte hiervan af te sluiten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "afsluitpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Afsluitpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Dijkpaal>
        a                      skos:Concept;
        rdfs:label             "dijkpaal"@nl;
        skos:definition        "Een markant punt op de waterkering of op het strand dat dient als referentiepunt voor afstandsaanduidingen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "dijkpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Dijkpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Drukknoppaal>
        a                      skos:Concept;
        rdfs:label             "drukknoppaal"@nl;
        skos:definition        "Paal met een lengte van ongeveer 1 m, met drukknop waarmee de verkeersdeelnemer zich meldt bij een verkeersregelinstallatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "drukknoppaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Drukknoppaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Grensmarkering>
        a                      skos:Concept;
        rdfs:label             "grensmarkering"@nl;
        skos:definition        "Paal ter afbakening van een grens."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "grensmarkering"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Grensmarkering> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Haltepaal>
        a                      skos:Concept;
        rdfs:label             "haltepaal"@nl;
        skos:definition        "Paal met daarop de dienstregeling ten behoeve van het openbaar vervoer."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "haltepaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Haltepaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Hectometerpaal>
        a                      skos:Concept;
        rdfs:label             "hectometerpaal"@nl;
        skos:definition        "Paaltje of bordje geplaatst langs de weg, waarop een hectometerwaarde (weg) of kilometrering (vaarweg) is vermeld eventueel gevolgd door een letter."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "hectometerpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Hectometerpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Lichtmast>
        a                      skos:Concept;
        rdfs:label             "lichtmast"@nl;
        skos:definition        "Mast bestemd voor het dragen van een of meer verlichtingsarmaturen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "lichtmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Lichtmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Poller>
        a                      skos:Concept;
        rdfs:label             "poller"@nl;
        skos:definition        "Een poller of inzinkbare paal is een paal die door een elektrische of hydraulische aandrijving uit een wegdek omhoog wordt gestuurd en die dient om het autoverkeer te reguleren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "poller"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Poller> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Portaal>
        a                      skos:Concept;
        rdfs:label             "portaal"@nl;
        skos:definition        "Geheel van twee of meer ondersteuningsconstructies die door een ligger zijn verbonden, bedoelt voor het aanbrengen van verkeersaanduidingen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "portaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Portaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Praatpaal>
        a                      skos:Concept;
        rdfs:label             "praatpaal"@nl;
        skos:definition        "Stalen of kunststof paal langs verkeerswegen welke bedoeld is telefonisch contact te leggen met een centrale meldkamer (ANWB)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "praatpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Praatpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Telpaal>
        a                      skos:Concept;
        rdfs:label             "telpaal"@nl;
        skos:definition        "Paal waaraan de verkeersteller is bevestigd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "telpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Telpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verkeersbordpaal>
        a                      skos:Concept;
        rdfs:label             "verkeersbordpaal"@nl;
        skos:definition        "Paal waaraan een of meerdere verkeersborden zijn bevestigd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verkeersbordpaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verkeersbordpaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verkeersregelinstallatiepaal>
        a                      skos:Concept;
        rdfs:label             "verkeersregelinstallatiepaal"@nl;
        skos:definition        "Paal met daaraan bevestigd de verkeersregelinstallatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verkeersregelinstallatiepaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verkeersregelinstallatiepaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Vlaggenmast>
        a                      skos:Concept;
        rdfs:label             "vlaggenmast"@nl;
        skos:definition        "Paal bedoeld om vlaggen aan te hangen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "vlaggenmast"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Vlaggenmast> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typePut>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typePut> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Benzine-Olieput>
        a                      skos:Concept;
        rdfs:label             "benzine- / olieput"@nl;
        skos:definition        "Putdeksel die toegang geeft tot een benzine- of olietank ten behoeve van vullen, onderhoud of inspectie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "benzine- / olieput"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Benzine-Olieput> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Brandkraan-put>
        a                      skos:Concept;
        rdfs:label             "brandkraan / -put"@nl;
        skos:definition        "Op de drinkwaterleiding aangesloten kraan, of een put voor het plaatsen van een brandkraan, op of nabij de openbare weg, voor brandbestrijding."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "brandkraan / -put"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Brandkraan-put> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Drainageput>
        a                      skos:Concept;
        rdfs:label             "drainageput"@nl;
        skos:definition        "Put welke toegang geeft naar een poreuze of geperforeerde buisleiding, aangebracht onder de grond om de afwatering van de grond te verbeteren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "drainageput"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Drainageput> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Gasput>
        a                      skos:Concept;
        rdfs:label             "gasput"@nl;
        skos:definition        "Put met afsluitkraan ten behoeve van het ondergrondse leidingenstelsel voor gastransport."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gasput"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gasput> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Inspectie-Rioolput>
        a                      skos:Concept;
        rdfs:label             "inspectie- / rioolput"@nl;
        skos:definition        "Put die toegang geeft tot een (riool)leiding."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "inspectie- / rioolput"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Inspectie-Rioolput> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Waterleidingput>
        a                      skos:Concept;
        rdfs:label             "waterleidingput"@nl;
        skos:definition        "Put met afsluitkraan ten behoeve van het ondergrondse leidingenstelsel voor watertransport."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "waterleidingput"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Waterleidingput> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Geluidsscherm>
        a                      skos:Concept;
        rdfs:label             "geluidsscherm"@nl;
        skos:definition        "Een scheiding bedoeld om geluidshinder in de buitenlucht te verminderen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "geluidsscherm"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Geluidsscherm> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kademuur>
        a                      skos:Concept;
        rdfs:label             "kademuur"@nl;
        skos:definition        "Verticale wand ter scheiding van land en water, opgebouwd uit een muur van gemetselde stenen of gestort beton."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "kademuur"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kademuur> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Muur>
        a                      skos:Concept;
        rdfs:label             "muur"@nl;
        skos:definition        "Een scheiding gemaakt van steen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "muur"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Muur> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeScheiding>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeScheiding> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_typeScheiding>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_typeScheiding> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Walbescherming>
        a                      skos:Concept;
        rdfs:label             "walbescherming"@nl;
        skos:definition        "Een nagenoeg verticale wand tot kering van grond om afkalving van water te voorkomen, niet zijnde een kademuur."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "walbescherming"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Walbescherming> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Draadraster>
        a                      skos:Concept;
        rdfs:label             "draadraster"@nl;
        skos:definition        "Kunstmatige terreinafscheiding, niet zijnde een faunaraster, in de vorm van een overwegend houten, metalen of kunststoffen rechtopstaande palen met daartussen een of meerdere draden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "draadraster"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Draadraster> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Faunaraster>
        a                      skos:Concept;
        rdfs:label             "faunaraster"@nl;
        skos:definition        "Kunstmatig aangebrachte scheiding van metaaldraad tussen palen, bedoeld voor het leiden van dieren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "faunaraster"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Faunaraster> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeSensor>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeSensor> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Camera>
        a                      skos:Concept;
        rdfs:label             "camera"@nl;
        skos:definition        "Installatie voor de registratie van beelden van situaties, waarvan direkte observatie moeilijk of niet permanent mogelijk is."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "camera"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Camera> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Debietmeter>
        a                      skos:Concept;
        rdfs:label             "debietmeter"@nl;
        skos:definition        "Een instrument dat de (afvoer)capaciteit van de volumestroom meet."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "debietmeter"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Debietmeter> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Detectielus>
        a                      skos:Concept;
        rdfs:label             "detectielus"@nl;
        skos:definition        "In de verharding opgenomen lusvormig onderdeel van een verkeersdetector."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "detectielus"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Detectielus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Flitser>
        a                      skos:Concept;
        rdfs:label             "flitser"@nl;
        skos:definition        "Een flitser bevat een mechanisme om een snelheidsmeting uit te voeren om snelheidsovertredingen in het verkeer te kunnen vaststellen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "flitser"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Flitser> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GmsSensor>
        a                      skos:Concept;
        rdfs:label             "GMS sensor"@nl;
        skos:definition        "Gladheidsmeldsysteem (GMS) waarmee de kans op gladheid wordt voorspeld aan de hand van meting en interpretatie van de parameters die een rol spelen bij het ontstaan van gladheid."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "GMS sensor"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GmsSensor> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Hoogtedetectieapparaat>
        a                      skos:Concept;
        rdfs:label             "hoogtedetectieapparaat"@nl;
        skos:definition        "Een mechanisch of elektronisch waarschuwingssysteem, dat in werking treedt bij overschrijding van de aangegeven maximale doorrijhoogte."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "hoogtedetectieapparaat"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Hoogtedetectieapparaat> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Lichtcel>
        a                      skos:Concept;
        rdfs:label             "lichtcel"@nl;
        skos:definition        "Lichtcel waarmee het verlichtingsniveau naar een lager verlichtingsniveau omgeschakeld wordt (dimmen) wanneer de situatie dit toelaat."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "lichtcel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Lichtcel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/RadarDetector>
        a                      skos:Concept;
        rdfs:label             "radar detector"@nl;
        skos:definition        "Met een radardetector wordt het verkeer gedetecteerd, bijvoorbeeld voor het beïnvloeden van verkeerslichten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "radar detector"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/RadarDetector> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Waterstandmeter>
        a                      skos:Concept;
        rdfs:label             "waterstandmeter"@nl;
        skos:definition        "Een meter die de waterstand, over het algemeen ten opzichte van NAP, meet."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
