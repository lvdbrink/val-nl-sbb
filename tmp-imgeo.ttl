        rdfs:label             "functioneel beheer: hondenuitlaatplaats"@nl;
        skos:definition        "Een uitlaatplaats waar uw hond zijn behoefte kan/ mag doen waarbij geen opruimplicht bestaat."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "functioneel beheer: hondenuitlaatplaats"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/FunctioneelBeheerHondenuitlaatplaats> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/InfrastructuurVerkeerEnVervoer>
        a                      skos:Concept;
        rdfs:label             "infrastructuur verkeer en vervoer"@nl;
        skos:definition        "Gebied primair in gebruik voor verkeer en vervoer, waaronder verstaan spoorwegen, wegdelen, vliegverkeersbanen, parkeerterreinen, bermen en de ondersteunende objecten als kunstwerken."@nl;
