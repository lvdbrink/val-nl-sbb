        rdfs:label             "kanaal"@nl;
        skos:definition        "Een gegraven grote waterloop die dient voor scheepvaart en/of watertransport."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "kanaal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kanaal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/MeerPlasVenVijver>
        a                      skos:Concept;
        rdfs:label             "meer, plas, ven, vijver"@nl;
        skos:definition        "Een massa stilstaand landoppervlaktewater."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "meer, plas, ven, vijver"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/MeerPlasVenVijver> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Rivier>
        a                      skos:Concept;
        rdfs:label             "rivier"@nl;
        skos:definition        "Het water, dat ten atmosferische neerslag op hellende terreinen valt, vloeit, voor zover het niet verdampt of door planten wordt opgenomen, tezamen tot een waterloop en stroomt naar laaggelegen streken. Zulk een natuurlijke afvloeiing heet een rivier."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rivier"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Rivier> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Sloot>
        a                      skos:Concept;
        rdfs:label             "sloot"@nl;
        skos:definition        "Algemene benaming voor een waterloop van beperkte breedte die stilstaand of slechts langzaam stromend water bevat."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "sloot"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Sloot> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeWeginrichting>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeWeginrichting> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Geenwaarde>
        a                      skos:Concept;
        rdfs:label             "geenWaarde"@nl;
        skos:definition        "Element heeft in werkelijkheid geen waarde."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "geenWaarde"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Geenwaarde> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Nietgeautoriseerd>
        a                      skos:Concept;
        rdfs:label             "nietGeautoriseerd"@nl;
        skos:definition        "Deze zender vindt dat de ontvanger niet geautoriseerd is om de waarde te kennen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "nietGeautoriseerd"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Nietgeautoriseerd> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Nietondersteund>
        a                      skos:Concept;
        rdfs:label             "nietOndersteund"@nl;
        skos:definition        "Zender houdt in zijn registratie geen waarde voor dit attribuut bij. Geldt voor alle objecten van dit objecttype."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "nietOndersteund"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Nietondersteund> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Vastgesteldonbekend>
        a                      skos:Concept;
        rdfs:label             "vastgesteldOnbekend"@nl;
        skos:definition        "Er is vastgesteld dat de waarde van het attribuut onbekend is en hoogst waarschijnlijk niet meer kan worden achterhaald (bijvoorbeeld omdat het brondocument onleesbaar is of het object niet meer bestaat in de werkelijkheid)."@nl;
