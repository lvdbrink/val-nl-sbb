        rdfs:label             "infrastructuur waterstaatswerken"@nl;
        skos:definition        "Gebied grenzend aan oppervlaktewater, primair in gebruik voor de oppervlaktewaterhuishouding (waterafvoer, wateraanvoer en waterconservering)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "infrastructuur waterstaatswerken"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/InfrastructuurWaterstaatswerken> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Landbouw>
