        skos:prefLabel         "zand- / zoutbak"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Zand-Zoutbak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeBord>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeBord> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/DynamischeSnelheidsindicator>
