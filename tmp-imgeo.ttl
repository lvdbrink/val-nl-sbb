        rdfs:label             "bron"@nl;
        skos:definition        "Grondwater dat op natuurlijke wijze uit het aardoppervlak tevoorschijn komt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bron"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bron> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Gracht>
