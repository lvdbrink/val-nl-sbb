PREFIX dct:      <http://purl.org/dc/terms/>
PREFIX extnlsbb: <http://extnlsbb.begrippenxl.nl/>
PREFIX foaf:     <http://xmlns.com/foaf/0.1/>
PREFIX isothes:  <http://purl.org/iso25964/skos-thes#>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos:     <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd:      <http://www.w3.org/2001/XMLSchema#>

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kolk>
        a                      skos:Concept;
        rdfs:label             "kolk"@nl;
        skos:definition        "Op het riool aangesloten voorziening voor de opvang van hemel- en afvalwater afkomstig van erop aangesloten oppervlakken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "kolk"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kolk> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Molgoot>
        a                      skos:Concept;
        rdfs:label             "molgoot"@nl;
        skos:definition        "Smalle goot (lijngeometrie) in de lengterichting van de verharding, met veelal een cirkelsegment als dwarsprofiel."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "molgoot"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Molgoot> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Watervlakte>
        a                      skos:Concept;
        rdfs:label             "watervlakte"@nl;
        skos:definition        "Alle oppervlakken die vrij permanent met zoet water zijn bedekt. (zoals meer, plas, ven, vijver)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "watervlakte"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Watervlakte> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Haag>
        a                      skos:Concept;
        rdfs:label             "haag"@nl;
        skos:definition        "Een rijvormige afscheiding van zeer beperkte breedte bestaande uit aangeplante aaneengesloten struiken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "haag"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Haag> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Weg>
        a                      skos:Concept;
        rdfs:label             "Weg"@nl;
        skos:definition        "Gebaand gedeelte voor het wegverkeer en vliegverkeer te land."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "Weg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Weg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Erf>
        a                      skos:Concept;
        rdfs:label             "erf"@nl;
        skos:definition        "Terreindeel dat bij een pand of overig bouwwerk hoort, dat niet nader wordt ingewonnen en dat bestaat uit een mengvorm van begroeiing, verharding, en/of water."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "erf"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Erf> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Abri>
        a                      skos:Concept;
        rdfs:label             "abri"@nl;
        skos:definition        "Overdekte wachtplaats voor passagiers van het openbaar vervoer."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "abri"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Abri> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Afvalbak>
        a                      skos:Concept;
        rdfs:label             "afvalbak"@nl;
        skos:definition        "Bak of korf in de openbare ruimte met een permanent karakter; bedoeld voor het verzamelen van (meestal los) afval."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "afvalbak"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Afvalbak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bank>
        a                      skos:Concept;
        rdfs:label             "bank"@nl;
        skos:definition        "Aaneengesloten zitplaats voor verscheidene personen, bedoeld voor openbaar gebruik en geplaatst in de openbare ruimte (vnl. in parken, plantsoenen, bossen en langs wegen)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bank"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bank> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bordes>
        a                      skos:Concept;
        rdfs:label             "bordes"@nl;
        skos:definition        "Een verhard oppervlak, eventueel verhoogd en/of uitgevoerd met treden, grenzend aan een pand en primair bedoeld voor gebruik door voetgangers."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bordes"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bordes> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bunker>
        a                      skos:Concept;
        rdfs:label             "bunker"@nl;
        skos:definition        "Een bunker is een militair verdedigingswerk dat een zekere mate van bescherming biedt tegen beschietingen en bombardementen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bunker"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bunker> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Damwand>
        a                      skos:Concept;
        rdfs:label             "damwand"@nl;
        skos:definition        "Een grondkerende constructie die bestaat uit een verticaal in de grond geplaatste wand."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "damwand"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Damwand> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Fontein>
        a                      skos:Concept;
        rdfs:label             "fontein"@nl;
        skos:definition        "Een fontein is een natuurlijke of kunstmatige installatie die water spuit."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "fontein"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Fontein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Herdenkingsmonument>
        a                      skos:Concept;
        rdfs:label             "herdenkingsmonument"@nl;
        skos:definition        "Langs de weg of elders in het terrein aangelegd object ter herdenking van personen of evenementen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "herdenkingsmonument"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Herdenkingsmonument> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Installatie>
        a                       skos:Concept;
        rdfs:label              "Installatie"@nl;
        isothes:broaderGeneric  <http://definities.geostandaarden.nl/imgeo/id/begrip/Cityfurniture>;
        skos:definition         "Samenhangend systeem dat een bepaald doel dient."@nl;
        skos:inScheme           <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel          "Installatie"@nl;
        skos:topConceptOf       <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf   <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Installatie> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kunstobject>
        a                      skos:Concept;
        rdfs:label             "kunstobject"@nl;
        skos:definition        "Een object dat als kunst gezien wordt en een bepaalde schoonheid heeft, niet door de natuur gemaakt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "kunstobject"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kunstobject> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/OpenLoods>
        a                      skos:Concept;
        rdfs:label             "open loods"@nl;
        skos:definition        "Niet verplaatsbaar licht gebouw met een open gevel, bestemd als berg- of werkplaats of als tijdelijk onderdak voor andere doeleinden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "open loods"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/OpenLoods> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/OpenbaarToilet>
        a                      skos:Concept;
        rdfs:label             "openbaar toilet"@nl;
        skos:definition        "Voor mensen bedoeld toilet niet zijnde een pand, langs de openbare weg."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "openbaar toilet"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/OpenbaarToilet> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Opslagtank>
        a                      skos:Concept;
        rdfs:label             "opslagtank"@nl;
        skos:definition        "Opslagfaciliteit voor vloeistoffen. Alleen bovengrondse opslagtanks worden opgenomen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "opslagtank"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Opslagtank> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Picknicktafel>
        a                      skos:Concept;
        rdfs:label             "picknicktafel"@nl;
        skos:definition        "Een picknicktafel is een tafel met vaak daaraan gemonteerde zitbanken of stoelen die kan gebruikt worden om te picknicken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "picknicktafel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Picknicktafel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Pomp>
        a                      skos:Concept;
        rdfs:label             "pomp"@nl;
        skos:definition        "Werktuig dat door middel van een verschil in druk vloeistoffen of gassen verplaatst."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "pomp"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Pomp> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Sirene>
        a                      skos:Concept;
        rdfs:label             "sirene"@nl;
        skos:definition        "Een apparaat dat geluiden van variabele toonhoogte kan voortbrengen met als functie waarschuwingsdoeleinden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "sirene"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Sirene> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Speelvoorziening>
        a                      skos:Concept;
        rdfs:label             "speelvoorziening"@nl;
        skos:definition        "Aard en nagelvast met de grond verbonden constructie in de openbare ruimte, bedoeld als speelmateriaal voor kinderen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "speelvoorziening"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Speelvoorziening> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Toegangstrap>
        a                      skos:Concept;
        rdfs:label             "toegangstrap"@nl;
        skos:definition        "Niet afsluitbare trap (of trappenhuis) die toegang biedt aan een gebouw."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "toegangstrap"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Toegangstrap> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Voorde>
        a                      skos:Concept;
        rdfs:label             "voorde"@nl;
        skos:definition        "Een doorwaadbare, doorgaans verharde, plaats in de waterloop, die dient voor de oversteek van die waterloop."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "voorde"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Voorde> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Vuilvang>
        a                      skos:Concept;
        rdfs:label             "vuilvang"@nl;
        skos:definition        "Een voorziening om de waterloop dan wel één of meerdere objecten benedenstrooms te vrijwaren van drijvend vuil en dergelijke."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "vuilvang"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Vuilvang> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Windturbine>
        a                      skos:Concept;
        rdfs:label             "windturbine"@nl;
        skos:definition        "Turbine waarin winddruk omgezet wordt in mechanische energie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "windturbine"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Windturbine> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zonnepaneel>
        a                      skos:Concept;
        rdfs:label             "zonnepaneel"@nl;
        skos:definition        "Een zonnepaneel is een paneel dat zonne-energie omzet in elektriciteit."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "zonnepaneel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Zonnepaneel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Overkapping>
        a                      skos:Concept;
        rdfs:label             "overkapping"@nl;
        skos:definition        "Een afzonderlijk staande overdekking rustend op kolommen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "overkapping"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Overkapping> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bak>
        a                       skos:Concept;
        rdfs:label              "Bak"@nl;
        isothes:broaderGeneric  <http://definities.geostandaarden.nl/imgeo/id/begrip/Cityfurniture>;
        skos:definition         "Object met een permanent karakter dat dient om iets in te bergen of te verzamelen."@nl;
        skos:inScheme           <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel          "Bak"@nl;
        skos:topConceptOf       <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf   <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zandverstuiving>
        a                      skos:Concept;
        rdfs:label             "zandverstuiving"@nl;
        skos:definition        "Een gebied met zandige bodem waarvan delen van het gebied zonder vegetatie zijn, door invloed van wind."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "zandverstuiving"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Zandverstuiving> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GriendEnHakhout>
        a                      skos:Concept;
        rdfs:label             "griend en hakhout"@nl;
        skos:definition        "Terreindeel met opgaande begroeiing van loofbomen, in een dicht groeiverband, en die periodiek wordt afgezet."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "griend en hakhout"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GriendEnHakhout> .

<http://definities.geostandaarden.nl/imgeo>
        a                      skos:ConceptScheme , <http://www.w3.org/ns/prov#Entity> , <http://www.w3.org/ns/adms#Asset>;
        rdfs:comment           "Het is een begrippenkader voor IMGeo. Het IMGeo is een uitbreiding op de BGT."@nl;
        rdfs:label             "Model"@nl;
