        rdfs:label             "historie"@nl;
        skos:definition        "Situatie waarin het geregistreerde object fysiek niet meer bestaat."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "historie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Historie> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Plan>
        a                      skos:Concept;
        rdfs:label             "plan"@nl;
        skos:definition        "Situatie die ontstaat op het moment van verlening van een beschikking voor bouw of aanleg en duurt tot het moment waarop het object gereed is voor het beoogde gebruik."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "plan"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Plan> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeBak>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeBak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/AfvalApartPlaats>
        a                      skos:Concept;
        rdfs:label             "afval apart plaats"@nl;
        skos:definition        "Boven- of ondergrondse opslagplaats voor het gescheiden inzamelen van afval, met stortkoker(s) op het straatniveau."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "afval apart plaats"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/AfvalApartPlaats> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bloembak>
        a                      skos:Concept;
        rdfs:label             "bloembak"@nl;
        skos:definition        "Bak in de openbare ruimte met een permanent karakter, waarin planten of struiken zijn geplant."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bloembak"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bloembak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Container>
        a                      skos:Concept;
        rdfs:label             "container"@nl;
        skos:definition        "Nagelvast met de grond verbonden inzamelmiddel voor afvalstoffen, doorgaans van metaal of kunststof waarin afvalstoffen worden verzameld, bewaard en waaruit deze afvalstoffen vervolgens worden overgeladen in een inzamelvoertuig."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "container"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Container> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Drinkbak>
        a                      skos:Concept;
        rdfs:label             "drinkbak"@nl;
        skos:definition        "Bak gevuld met water, waaruit vee of wild kan drinken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "drinkbak"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Drinkbak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zand-Zoutbak>
