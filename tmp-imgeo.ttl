        rdfs:label             "brievenbus"@nl;
        skos:definition        "Uitpandige kast waar post in kan worden gedeponeerd ter bezorging."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "brievenbus"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Brievenbus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Fietsenkluis>
