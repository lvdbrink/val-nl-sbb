        rdfs:label             "greppel, droge sloot"@nl;
        skos:definition        "Een ten behoeve van de waterbeheersing gegraven geul die al dan niet met water bedekt is."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "greppel, droge sloot"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GreppelDrogeSloot> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_typeWater>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_typeWater> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Waterloop>
