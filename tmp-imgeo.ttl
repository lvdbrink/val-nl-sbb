        rdfs:label             "beek"@nl;
        skos:definition        "Een natuurlijke smalle waterloop zonder getij."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "beek"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Beek> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bron>
