        rdfs:label             "gracht"@nl;
        skos:definition        "Een gracht is een gegraven greppel met water, die hoofdzakelijk voorkomt in oude steden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gracht"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gracht> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Haven>
        a                      skos:Concept;
        rdfs:label             "haven"@nl;
        skos:definition        "Een tot ligplaats van schepen geschikt, natuurlijk of gegraven waterbekken aan zee of aan de oever van een rivier of binnenwater, dat beschutting biedt tegen wind en golven."@nl;
