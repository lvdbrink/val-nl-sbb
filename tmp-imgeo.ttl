        skos:prefLabel         "haven"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Haven> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kanaal>
