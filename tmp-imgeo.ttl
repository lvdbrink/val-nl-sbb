        rdfs:label             "landbouw"@nl;
        skos:definition        "Gebied primair in gebruik voor land- en tuinbouwproductie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "landbouw"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Landbouw> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/MaatschappelijkeEnofPublieksvoorziening>
