<http://definities.geostandaarden.nl/imgeo/id/begrip/Groenvoorziening_fysiekVoorkomenOndersteunendWegdeel>
        a                      skos:Concept;
        rdfs:label             "groenvoorziening"@nl;
        skos:definition        "Terreindeel met aangelegde beplanting, meestal gras, heesters of struiken."@nl;
