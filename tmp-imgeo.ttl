        skos:prefLabel         "dynamische snelheidsindicator"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/DynamischeSnelheidsindicator> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Informatiebord>
        a                      skos:Concept;
        rdfs:label             "informatiebord"@nl;
        skos:definition        "Een bord met daarop specifieke actuele informatie, zoals plattegronden of vertrektijden."@nl;
