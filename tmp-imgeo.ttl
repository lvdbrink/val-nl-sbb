        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Waterloop> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zee>
        a                      skos:Concept;
        rdfs:label             "zee"@nl;
        skos:definition        "Uitgestrekt oppervlak zout water."@nl;
