        rdfs:label             "scheepvaartbord"@nl;
        skos:definition        "Bord waarop een scheepvaartteken is aangebracht en waarvan de uitvoering als richtlijn is voorgeschreven volgens 'Richtlijnen Scheepvaarttekens (RST 2008)'."@nl;
