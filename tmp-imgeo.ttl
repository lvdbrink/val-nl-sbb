        a                      skos:Concept;
        rdfs:label             "boomspiegel"@nl;
        skos:definition        "Het stuk grond rondom de stam van een boom dat van boven toegankelijk is voor lucht en water."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "boomspiegel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Boomspiegel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Geleideconstructie>
        a                      skos:Concept;
        rdfs:label             "geleideconstructie"@nl;
        skos:definition        "Bermbeveiligingsconstructie bedoeld voor fysieke geleiding van voertuigen die uit de koers zijn geraakt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "geleideconstructie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Geleideconstructie> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Lijnafwatering>
        a                      skos:Concept;
        rdfs:label             "lijnafwatering"@nl;
        skos:definition        "Goot in de lengterichting van de verharding, niet zijnde molgoot. Bijvoorbeeld roostergoot en verholen goot."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "lijnafwatering"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Lijnafwatering> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Rooster>
        a                      skos:Concept;
        rdfs:label             "rooster"@nl;
        skos:definition        "Een rooster niet zijnde lijnafwatering of wildrooster."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rooster"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Rooster> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verblindingswering>
        a                      skos:Concept;
        rdfs:label             "verblindingswering"@nl;
        skos:definition        "Constructie bedoeld om verblinding van weggebruikers door tegenlicht te voorkomen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verblindingswering"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verblindingswering> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Wegmarkering>
        a                      skos:Concept;
        rdfs:label             "wegmarkering"@nl;
        skos:definition        "Op of in het oppervlak van de verharding aangebrachte tekens ter geleiding, waarschuwing, regeling of informatie van het verkeer."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "wegmarkering"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Wegmarkering> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Wildrooster>
        a                      skos:Concept;
        rdfs:label             "wildrooster"@nl;
        skos:definition        "Horizontaal raamwerk dat dient om wild de doorgang te beletten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "wildrooster"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Wildrooster> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bestaand>
