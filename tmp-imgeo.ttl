        rdfs:label             "carpoolplaats"@nl;
        skos:definition        "Parkeerplaats die qua ligging en ontsluiting geschikt is voor carpooling."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "carpoolplaats"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Carpoolplaats> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/FunctioneelBeheer>
        a                      skos:Concept;
        rdfs:label             "functioneel beheer"@nl;
        skos:definition        "Gebied waar een specifiek beheer voor benodigd is, louter bepaald vanuit beheersoogpunt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "functioneel beheer"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/FunctioneelBeheer> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/FunctioneelBeheerHondenuitlaatplaats>
