<http://definities.geostandaarden.nl/imgeo/id/begrip/Bouwland>
        a                      skos:Concept;
        rdfs:label             "bouwland"@nl;
        skos:definition        "Terreindeel in gebruik als akker, met gewassen die in een teelt roulatieschema zijn opgenomen. Kan tijdelijk zonder gewas zijn of braak liggen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bouwland"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bouwland> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Hek>
        a                      skos:Concept;
        rdfs:label             "hek"@nl;
        skos:definition        "Een hekwerk of schutting, typisch ten behoeve van erfafscheiding."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "hek"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Hek> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Berm>
        a                      skos:Concept;
        rdfs:label             "berm"@nl;
        skos:definition        "Een strook grond langs een weg of spoorweg."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "berm"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Berm> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_functieOndersteunendWegdeel>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_functieOndersteunendWegdeel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verkeerseiland>
        a                      skos:Concept;
        rdfs:label             "verkeerseiland"@nl;
        skos:definition        "Ondersteunend wegdeel van beperkte omvang, uitgevoerd als verhoging of wegmarkering, dat wordt omsloten door wegdelen en ten doel heeft verkeersstromen te scheiden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verkeerseiland"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verkeerseiland> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_functieSpoor>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_functieSpoor> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Sneltram>
        a                      skos:Concept;
        rdfs:label             "sneltram"@nl;
        skos:definition        "Spoor voor een boven- danwel ondergrondse interlokale tram met een vrije baan."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "sneltram"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Sneltram> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Tram>
        a                      skos:Concept;
        rdfs:label             "tram"@nl;
        skos:definition        "Spoor voor een railvoertuig voor personenvervoer voor de korte afstand."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "tram"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Tram> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_functieSpoor>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_functieSpoor> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Trein>
        a                      skos:Concept;
        rdfs:label             "trein"@nl;
        skos:definition        "Spoor voor een railvoertuig voor de langere afstand dat sneller dan 45 km per uur kan, bestaande uit een enkele of een reeks van locomotieven, treinstellen en/of wagons."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "trein"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Trein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/(haven)kraan>
        a                      skos:Concept;
        rdfs:label             "(haven)kraan"@nl;
        skos:definition        "Spoorbaan waarop een hefkraan (bij een haven) zich voortbeweegt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "(haven)kraan"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/(haven)kraan> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/BaanVoorVliegverkeer>
        a                      skos:Concept;
        rdfs:label             "baan voor vliegverkeer"@nl;
        skos:definition        "Wegdeel uitsluitend bedoeld voor vliegverkeer."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "baan voor vliegverkeer"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/BaanVoorVliegverkeer> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Fietspad>
        a                      skos:Concept;
        rdfs:label             "fietspad"@nl;
        skos:definition        "Wegdeel met name bestemd voor fietsers en, indien toegestaan, bromfietsers en dat afgescheiden is van de andere wegdelen niet uitsluitend door markering."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "fietspad"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Fietspad> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Inrit>
        a                      skos:Concept;
        rdfs:label             "inrit"@nl;
        skos:definition        "Toegangswegen, oprijlanen en dergelijke met verkeersfunctie die leiden naar afgelegen erven en terreinen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "inrit"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Inrit> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Ov-baan>
        a                      skos:Concept;
        rdfs:label             "OV-baan"@nl;
        skos:definition        "Wegdeel dat uitsluitend is bestemd en gemarkeerd voor openbaar vervoer en afgescheiden is van de andere wegdelen niet uitsluitend door markering."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "OV-baan"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Ov-baan> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Overweg>
        a                      skos:Concept;
        rdfs:label             "overweg"@nl;
        skos:definition        "Een gelijkvloerse kruising van een wegdeel en een wegdeel type ov-baan met spoor type trein of sneltram."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "overweg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Overweg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Parkeervlak>
        a                      skos:Concept;
        rdfs:label             "parkeervlak"@nl;
        skos:definition        "Wegdeel bestemd voor het parkeren van motorvoertuigen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "parkeervlak"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Parkeervlak> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/RijbaanAutosnelweg>
        a                      skos:Concept;
        rdfs:label             "rijbaan autosnelweg"@nl;
        skos:definition        "Wegdeel dat onderdeel is van een weg uitsluitend bestemd voor snelverkeer en met gescheiden rijbanen en ongelijkvloerse kruisingen, daartoe aangeduid met het betreffende verkeersbord."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rijbaan autosnelweg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/RijbaanAutosnelweg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/RijbaanAutoweg>
        a                      skos:Concept;
        rdfs:label             "rijbaan autoweg"@nl;
        skos:definition        "Wegdeel dat onderdeel is van een weg uitsluitend bestemd voor snelverkeer, daartoe aangeduid met het betreffende verkeersbord."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rijbaan autoweg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/RijbaanAutoweg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/RijbaanLokaleWeg>
        a                      skos:Concept;
        rdfs:label             "rijbaan lokale weg"@nl;
        skos:definition        "Wegdeel dat onderdeel is van een weg van lokaal belang."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rijbaan lokale weg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/RijbaanLokaleWeg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/RijbaanRegionaleWeg>
        a                      skos:Concept;
        rdfs:label             "rijbaan regionale weg"@nl;
        skos:definition        "Wegdeel dat onderdeel is van een weg die een verbinding vormt tussen bewoonde oorden of tussen wijken binnen een dorp of stad."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rijbaan regionale weg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/RijbaanRegionaleWeg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Ruiterpad>
        a                      skos:Concept;
        rdfs:label             "ruiterpad"@nl;
        skos:definition        "Een wegdeel primair aangelegd voor het gebruik door ruiters."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "ruiterpad"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Ruiterpad> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Spoorbaan_functieWeg>
        a                      skos:Concept;
        rdfs:label             "spoorbaan"@nl;
        skos:definition        "Gebaand gedeelte voor het verkeer over rails."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "spoorbaan"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Spoorbaan_functieWeg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_functieWeg>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_functieWeg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Voetgangersgebied>
        a                      skos:Concept;
        rdfs:label             "voetgangersgebied"@nl;
        skos:definition        "Wegdeel alleen voor het gebruik door voetgangers, waarbij het door voetgangers te gebruiken gebied de volle breedte van de weg beslaat en het gebied een nadrukkelijk openbaar karakter heeft."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "voetgangersgebied"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Voetgangersgebied> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Voetpad>
        a                      skos:Concept;
        rdfs:label             "voetpad"@nl;
        skos:definition        "Wegdeel waar voetgangers gebruik van moeten maken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "voetpad"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Voetpad> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/VoetpadOpTrap>
        a                      skos:Concept;
        rdfs:label             "voetpad op trap"@nl;
        skos:definition        "Voetpad op verkeersinfrastructurele voorziening bestaande uit een constructie van treden, waarop men een hoger of lager gelegen plaats kan bereiken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "voetpad op trap"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/VoetpadOpTrap> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Woonerf>
        a                      skos:Concept;
        rdfs:label             "woonerf"@nl;
        skos:definition        "Wegdeel waar de verblijfsfunctie (lopen, spelen, ontmoeten enzovoorts) prioriteit heeft boven de verkeersfunctie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "woonerf"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Woonerf> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Calamiteitendoorsteek>
        a                      skos:Concept;
        rdfs:label             "calamiteitendoorsteek"@nl;
        skos:definition        "Een (Calamiteiten doorsteek) CADO heeft tot doel het verkeer op een rijbaan via een doorsteek van de weg te kunnen geleiden in geval van een calamiteit of werkzaamheden op de rijbaan. Een tweede doel is het faciliteren van toegang tot rijbanen voor hulpdiensten vanaf andere rijbanen of van een parallelweg."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "calamiteitendoorsteek"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Calamiteitendoorsteek> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verbindingsweg>
        a                      skos:Concept;
        rdfs:label             "verbindingsweg"@nl;
        skos:definition        "Een verbindingsweg is (in principe) een eenrichtingsweg, gelegen binnen een knooppunt of aansluiting, die onderdeel is van de wijze waarop de ongelijkvloersheid is gerealiseerd."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verbindingsweg"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verbindingsweg> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Verkeersdrempel>
        a                      skos:Concept;
        rdfs:label             "verkeersdrempel"@nl;
        skos:definition        "Verhoging in een regionale rijbaan, bedoeld om het gemotoriseerde verkeer met een lage snelheid te laten rijden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "verkeersdrempel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Verkeersdrempel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Boomteelt>
        a                      skos:Concept;
        rdfs:label             "boomteelt"@nl;
        skos:definition        "Grond in gebruik voor het kweken van jonge siergewassen, bomen enz. ten behoeve van een later gebruik elders."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "boomteelt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Boomteelt> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Duin>
        a                      skos:Concept;
        rdfs:label             "duin"@nl;
        skos:definition        "Verhoging of heuvel van zand of fijne losse aarde en verpulverd gesteente opgeworpen door wind of door stromend water."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "duin"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Duin> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Fruitteelt>
        a                      skos:Concept;
        rdfs:label             "fruitteelt"@nl;
        skos:definition        "Terreindeel begroeid met fruitbomen in de vorm van hoogstam en laagstamboomgaard, druiven of kleinfruit."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "fruitteelt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Fruitteelt> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GemengdBos>
        a                      skos:Concept;
        rdfs:label             "gemengd bos"@nl;
        skos:definition        "Terreindeel begroeid met een dusdanige aantal naald- en loofbomen dat deze een min of meer gesloten geheel vormen of, na volgroeiing van de bomen, zullen vormen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gemengd bos"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GemengdBos> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GraslandAgrarisch>
        a                      skos:Concept;
        rdfs:label             "grasland agrarisch"@nl;
        skos:definition        "Terreindeel met een vegetatie bestaande uit grassen en of grasachtigen, en met de in graslanden voorkomende kruiden, zijnde cultuurgrasland dat in gebruik is voor de veeteelt, bijvoorbeeld als weiland of als hooiland."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "grasland agrarisch"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GraslandAgrarisch> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GraslandOverig>
        a                      skos:Concept;
        rdfs:label             "grasland overig"@nl;
        skos:definition        "Terreindeel met een vegetatie bestaande uit grassen en of grasachtigen, en met de in graslanden voorkomende kruiden, dat niet in gebruik is voor agrarische doeleinden."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "grasland overig"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GraslandOverig> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Groenvoorziening_fysiekVoorkomenBegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "groenvoorziening"@nl;
        skos:definition        "Terreindeel met aangelegde beplanting, meestal gras, heesters of struiken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "groenvoorziening"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Groenvoorziening_fysiekVoorkomenBegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Heide>
        a                      skos:Concept;
        rdfs:label             "heide"@nl;
        skos:definition        "Terreindeel overwegend begroeid met heide en heideachtige vegetaties."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "heide"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Heide> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Houtwal>
        a                      skos:Concept;
        rdfs:label             "houtwal"@nl;
        skos:definition        "Terreindeel zijnde een afscheiding met beperkte breedte en beplant met bomen of struiken."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "houtwal"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Houtwal> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Kwelder>
        a                      skos:Concept;
        rdfs:label             "kwelder"@nl;
        skos:definition        "Buitendijks gelegen aangeslibd land van een wad, dat bij gewone vloed niet meer onder loopt."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "kwelder"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kwelder> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Loofbos>
        a                      skos:Concept;
        rdfs:label             "loofbos"@nl;
        skos:definition        "Terreindeel begroeid met een dusdanige aantal loofbomen dat deze een min of meer gesloten geheel vormen of, na volgroeiing van de bomen, zullen vormen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "loofbos"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Loofbos> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Moeras>
        a                      skos:Concept;
        rdfs:label             "moeras"@nl;
        skos:definition        "Terreindeel met moerasvegetatie in stilstaand water van geringe diepte zonder merkbare toe- of afvloeiing."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "moeras"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Moeras> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Naaldbos>
        a                      skos:Concept;
        rdfs:label             "naaldbos"@nl;
        skos:definition        "Terreindeel begroeid met een dusdanige aantal naaldbomen dat deze een min of meer gesloten geheel vormen of, na volgroeiing van de bomen, zullen vormen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "naaldbos"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Naaldbos> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Rietland>
        a                      skos:Concept;
        rdfs:label             "rietland"@nl;
        skos:definition        "Terreindeel overwegend begroeid met rietvegetatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "rietland"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Rietland> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Struiken>
        a                      skos:Concept;
        rdfs:label             "struiken"@nl;
        skos:definition        "Terreindeel bedekt met niet-gecultiveerde (natuurlijke), lage, houtachtige, overblijvende planten gekenmerkt door verschillende vertakkingen dicht bij de wortel en afwezigheid van opvallende stammen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "struiken"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Struiken> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_fysiekVoorkomenBegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_fysiekVoorkomenBegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Akkerbouw>
        a                      skos:Concept;
        rdfs:label             "akkerbouw"@nl;
        skos:definition        "Terreindeel in gebruik als akker, voor de teelt van akkerbouwgewassen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "akkerbouw"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Akkerbouw> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bodembedekkers_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "bodembedekkers"@nl;
        skos:definition        "Beheerde beplanting van groenvak in de openbare ruimte, zijnde bodembedekkers."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bodembedekkers"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bodembedekkers_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bollenteelt>
        a                      skos:Concept;
        rdfs:label             "bollenteelt"@nl;
        skos:definition        "Terreindeel in gebruik als akker, voor de teelt van bloembollen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bollenteelt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bollenteelt> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bosplantsoen_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "bosplantsoen"@nl;
        skos:definition        "Opgaande beplanting van houtachtige gewassen die struikvormend en/of boomvormend zijn. De soorten zijn als bosplantsoen opgekweekt en aangeplant.De beplanting kan open of gesloten zijn en bestaat vaak uit inheemse soorten. Onderscheidt zich van heesters omdat de sierkenmerken niet voorop staan."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bosplantsoen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bosplantsoen_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Braakliggend>
        a                      skos:Concept;
        rdfs:label             "braakliggend"@nl;
        skos:definition        "Terrein in gebruik als akker, maar tijdelijk niet beteeld met een landbouwgewas."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "braakliggend"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Braakliggend> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GeslotenDuinvegetatie>
        a                      skos:Concept;
        rdfs:label             "gesloten duinvegetatie"@nl;
        skos:definition        "Duin met een overwegend opgaande vegetatie van struiken en of bomen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gesloten duinvegetatie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GeslotenDuinvegetatie> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Gras-EnKruidachtigen_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "gras- en kruidachtigen"@nl;
        skos:definition        "(Grond met) een laagblijvende, aaneengesloten kruidachtige vegetatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gras- en kruidachtigen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gras-EnKruidachtigen_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Heesters_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "heesters"@nl;
        skos:definition        "Beplanting van houtige gewassen die struikvormend zijn en die al dan niet een gesloten geheel vormen. Het accent ligt op de sierwaarde, de beplanting kan uit één soort of uit meerdere soorten bestaan. Onder de heesters kan een houtachtige of kruidachtige onderbegroeiing aanwezig zijn. Het oppervlak met struikachtige gewassen is meer dan 50% van de totale oppervlakte van het vak."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "heesters"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Heesters_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/HoogstamBoomgaarden>
        a                      skos:Concept;
        rdfs:label             "hoogstam boomgaarden"@nl;
        skos:definition        "Terreindeel begroeid met hoogstamfruitbomen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "hoogstam boomgaarden"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/HoogstamBoomgaarden> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/KleinFruit>
        a                      skos:Concept;
        rdfs:label             "klein fruit"@nl;
        skos:definition        "Terreindeel begroeid met heesters voor zachtfruit zoals bessen of frambozen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "klein fruit"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/KleinFruit> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/LaagstamBoomgaarden>
        a                      skos:Concept;
        rdfs:label             "laagstam boomgaarden"@nl;
        skos:definition        "Terreindeel begroeid met laagstamfruitbomen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "laagstam boomgaarden"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/LaagstamBoomgaarden> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/OpenDuinvegetatie>
        a                      skos:Concept;
        rdfs:label             "open duinvegetatie"@nl;
        skos:definition        "Duin met een overwegend grasachtige vegetatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "open duinvegetatie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/OpenDuinvegetatie> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Planten_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "planten"@nl;
        skos:definition        "Beheerde niet nader gespecificeerde beplanting van groenvak in de openbare ruimte."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "planten"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Planten_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Struikrozen_fysiekVoorkomenBegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "struikrozen"@nl;
        skos:definition        "Beheerde beplanting van groenvak in de openbare ruimte, zijnde in struikvorm groeiende rozen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "struikrozen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Struikrozen_fysiekVoorkomenBegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Vollegrondsteelt>
        a                      skos:Concept;
        rdfs:label             "vollegrondsteelt"@nl;
        skos:definition        "Terreindeel in gebruik als akker, voor de teelt van tuinbouwgewassen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "vollegrondsteelt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Vollegrondsteelt> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Wijngaarden>
        a                      skos:Concept;
        rdfs:label             "wijngaarden"@nl;
        skos:definition        "Terreindeel begroeid met druivenstokken voor wijnbouw."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "wijngaarden"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Wijngaarden> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GeslotenVerharding_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "gesloten verharding"@nl;
        skos:definition        "Verharding bestaande uit een materiaal dat niet verwijderbaar is zonder definitieve destructie, zoals bijvoorbeeld bitumen, cement of kunststof."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gesloten verharding"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GeslotenVerharding_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/HalfVerhard_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "half verhard"@nl;
        skos:definition        "Verharding bestaande uit een door verdichting gebonden materiaal, of onsamenhangend materiaal."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "half verhard"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/HalfVerhard_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Onverhard_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "onverhard"@nl;
        skos:definition        "Terreindeel waar geen verharding of aaneengesloten vegetatie aanwezig is, niet zijnde zand. Braakliggend valt hier wel onder."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "onverhard"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Onverhard_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/OpenVerharding_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "open verharding"@nl;
        skos:definition        "Verharding gevormd door in verband aangebrachte elementen van beperkte afmetingen, zoals bijvoorbeeld klinkers en tegels."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "open verharding"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/OpenVerharding_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Transitie_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "transitie"@nl;
        skos:definition        "De waarde is tijdens transitie niet bekend."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "transitie"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Transitie_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Zand_fysiekVoorkomenOnbegroeidTerrein>
        a                      skos:Concept;
        rdfs:label             "zand"@nl;
        skos:definition        "Terreindeel dat grotendeels bedekt is met zand."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "zand"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Zand_fysiekVoorkomenOnbegroeidTerrein> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Asfalt_fysiekVoorkomenOnbegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "asfalt"@nl;
        skos:definition        "Gesloten verharding bestaande uit asfaltbeton of andere met bitumen gebonden materialen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "asfalt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Asfalt_fysiekVoorkomenOnbegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/BetonElement_fysiekVoorkomenOnbegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "beton element"@nl;
        skos:definition        "Geprepareerde elementen van beton zoals, trottoirbanden, opsluitbanden en stelconplaten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "beton element"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/BetonElement_fysiekVoorkomenOnbegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Betonstraatstenen_fysiekVoorkomenOnbegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "betonstraatstenen"@nl;
        skos:definition        "Verharding gemaakt van betonstraatstenen. Straatsteen die als goedkope vervanging van de gebakken klinkers is ontwikkeld."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "betonstraatstenen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
