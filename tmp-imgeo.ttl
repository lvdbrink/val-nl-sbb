        rdfs:label             "waterloop"@nl;
        skos:definition        "Een voor de waterbeheersing bestemde geul die meestal permanent water bevat (zoals rivier, kanaal, beek, sloot, gracht)."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
