        rdfs:label             "parkeerbeugel"@nl;
        skos:definition        "Een omklapbare beugel voor het afschermen van een parkeerplaats."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "parkeerbeugel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Parkeerbeugel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Reclamezuil>
