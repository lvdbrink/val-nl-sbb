        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "telefooncel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Telefooncel> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeVegetatieObject>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeVegetatieObject> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Boom>
