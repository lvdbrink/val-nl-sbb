        rdfs:label             "bewoning"@nl;
        skos:definition        "Gebied waarop panden of overige bouwwerken staan die voornamelijk gebruikt worden voor bewoning, inclusief erven en tuinen die bij de panden behoren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bewoning"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bewoning> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bushalte>
        a                      skos:Concept;
        rdfs:label             "bushalte"@nl;
        skos:definition        "Halteplaats voor bussen van het openbaar vervoer."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bushalte"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bushalte> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Carpoolplaats>
