<http://definities.geostandaarden.nl/imgeo/id/begrip/Weerstation>
        a                      skos:Concept;
        rdfs:label             "weerstation"@nl;
        skos:definition        "Een weerstation is een verzameling instrumenten die het weer kunnen meten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "weerstation"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Weerstation> .

