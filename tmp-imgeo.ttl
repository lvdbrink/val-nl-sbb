        skos:prefLabel         "asfalt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Asfalt_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/BetonElement_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "beton element"@nl;
        skos:definition        "Geprepareerde elementen van beton zoals, trottoirbanden, opsluitbanden en stelconplaten."@nl;
