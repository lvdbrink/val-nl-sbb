        skos:prefLabel         "kering"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Kering> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Niet-bgt_typeFunctioneelGebied>
        a                      skos:Concept;
        rdfs:label             "niet-bgt"@nl;
        skos:definition        "Het object is geen BGT object."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "niet-bgt"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Niet-bgt_typeFunctioneelGebied> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bedrijvigheid>
