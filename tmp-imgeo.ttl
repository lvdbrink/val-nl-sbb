        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "geleidewerk"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Geleidewerk> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Hoogtemerk>
