        a                      skos:Concept;
        rdfs:label             "boomschors"@nl;
        skos:definition        "Onverhard met als deklaag boomschors."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "boomschors"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Boomschors_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Bosplantsoen_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "bosplantsoen"@nl;
        skos:definition        "Opgaande beplanting van houtachtige gewassen die struikvormend en/of boomvormend zijn. De soorten zijn als bosplantsoen opgekweekt en aangeplant.De beplanting kan open of gesloten zijn en bestaat vaak uit inheemse soorten. Onderscheidt zich van heesters omdat de sierkenmerken niet voorop staan."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bosplantsoen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bosplantsoen_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Cementbeton_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "cementbeton"@nl;
        skos:definition        "Gesloten verharding bestaande uit gewapend of ongewapend beton."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "cementbeton"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Cementbeton_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GebakkenKlinkers_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "gebakken klinkers"@nl;
        skos:definition        "Verharding gemaakt van straatbakstenen. Gebakken klinkers worden voornamelijk geproduceerd uit grondstof van eigen bodem; de beddingen van onze rivieren."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gebakken klinkers"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/GebakkenKlinkers_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Gras-EnKruidachtigen_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "gras- en kruidachtigen"@nl;
        skos:definition        "(Grond met) een laagblijvende, aaneengesloten kruidachtige vegetatie."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gras- en kruidachtigen"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gras-EnKruidachtigen_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Grasklinkers_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "grasklinkers"@nl;
        skos:definition        "Elementenverharding bestaande uit elementen van beperkte afmetingen die ten behoeve van de doorgroei van grassen en kruiden, zijn voorzien van openingen of met tussenruimten aangebracht."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "grasklinkers"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Grasklinkers_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Gravel_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "gravel"@nl;
        skos:definition        "Gravel is een ondergrond van gemalen baksteen die veel wordt gebruikt bij tennis en ook wel op atletiekbanen."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "gravel"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gravel_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Grind_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "grind"@nl;
        skos:definition        "Ongebonden verharding bestaande uit kiezelmateriaal, waarvan de stenen in doorsnede variëren van 1 tot 5 cm."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "grind"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Grind_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Heesters_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "heesters"@nl;
        skos:definition        "Beplanting van houtige gewassen die struikvormend zijn en die al dan niet een gesloten geheel vormen. Het accent ligt op de sierwaarde, de beplanting kan uit één soort of uit meerdere soorten bestaan. Onder de heesters kan een houtachtige of kruidachtige onderbegroeiing aanwezig zijn. Het oppervlak met struikachtige gewassen is meer dan 50% van de totale oppervlakte van het vak."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "heesters"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Heesters_fysiekVoorkomenOndersteunendWegdeelPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Planten_fysiekVoorkomenOndersteunendWegdeelPlus>
        a                      skos:Concept;
        rdfs:label             "planten"@nl;
        skos:definition        "Beheerde niet nader gespecificeerde beplanting van groenvak in de openbare ruimte."@nl;
