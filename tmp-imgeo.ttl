        rdfs:label             "bedrijvigheid"@nl;
        skos:definition        "Gebied waarop panden of overige gebouwen staan, en / of niet bebouwde oppervlakte , voornamelijk gebruikt voor economische activiteiten en non-profit activiteiten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "bedrijvigheid"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Bedrijvigheid> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Begraafplaats>
        a                      skos:Concept;
        rdfs:label             "begraafplaats"@nl;
        skos:definition        "Een besloten gebied waar lichamen van overleden personen worden begraven. Ook worden op begraafplaatsen urnen as van gecremeerde lichamen bewaard."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "begraafplaats"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Begraafplaats> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Benzinestation>
