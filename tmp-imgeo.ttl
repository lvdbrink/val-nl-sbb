        rdfs:label             "windmeter"@nl;
        skos:definition        "Apparatuur waarmee de snelheid en de richting van de wind kan worden gemeten."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "windmeter"@nl;
