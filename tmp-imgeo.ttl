        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "slagboom"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Slagboom> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Telefooncel>
