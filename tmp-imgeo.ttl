<http://definities.geostandaarden.nl/imgeo/id/begrip/Bolder>
        a                      skos:Concept;
        rdfs:label             "bolder"@nl;
        skos:definition        "Een inrichting aan de wal, waar een schip, door middel van een tros of landvast, aan vastgelegd kan worden."@nl;
