        rdfs:label             "boom"@nl;
        skos:definition        "Een markante boom die geen onderdeel uitmaakt van een ander boom- of struikbeplanting."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
        skos:prefLabel         "boom"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Boom> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/GreppelDrogeSloot>
