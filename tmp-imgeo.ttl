        skos:prefLabel         "reclamebord"@nl;
        skos:topConceptOf      <http://definities.geostandaarden.nl/imgeo>;
        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Reclamebord> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Scheepvaartbord>
