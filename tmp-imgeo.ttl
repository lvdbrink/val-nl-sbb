        foaf:isPrimaryTopicOf  <http://definities.geostandaarden.nl/imgeo/doc/begrip/20200618000000/Gravel_fysiekVoorkomenOnbegroeidTerreinPlus> .

<http://definities.geostandaarden.nl/imgeo/id/begrip/Grind_fysiekVoorkomenOnbegroeidTerreinPlus>
        a                      skos:Concept;
        rdfs:label             "grind"@nl;
        skos:definition        "Ongebonden verharding bestaande uit kiezelmateriaal, waarvan de stenen in doorsnede variëren van 1 tot 5 cm."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
