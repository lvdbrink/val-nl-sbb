<http://definities.geostandaarden.nl/imgeo/id/begrip/Onverhard_fysiekVoorkomenOndersteunendWegdeel>
        a                      skos:Concept;
        rdfs:label             "onverhard"@nl;
        skos:definition        "Wegdelen waar geen verharding of aaneengesloten vegetatie aanwezig is."@nl;
        skos:inScheme          <http://definities.geostandaarden.nl/imgeo>;
